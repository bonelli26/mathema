{% assign tags = collection.all_tags %}
{% assign tagsSize = tags | size %}
{% assign productDataString = "" %}

{% assign productsByPriceLTH = collection.products | sort: 'price' %}
{% assign productsByPriceHTL = collection.products | sort: 'price' | reverse %}
{% assign productsAZ = collection.products | sort: 'title' %}
{% assign productsZA = collection.products | sort: 'title' | reverse %}
{% assign productsByCreatedAt = collection.products | sort: 'created_at' %}

{% assign thisProduct2 = section.settings.product %}

<div class="c-20 column" id="collection-grid" data-product-data="{% paginate collection.products by 3000 %}{% for thisProduct in collection.products  %}{% if forloop.index0 != 0 %}|||{% endif %}{{ thisProduct.available }}||{{ thisProduct.price | money_without_currency }}{% if thisProduct.options_by_name['emitting color'] %}||{% for value in thisProduct.options_by_name['emitting color'].values  %}{{ value }}{% endfor %}{% endif %}{% endfor %}{% endpaginate %}">
    <div class="collection-hero hero-short">
        <div class="left">
            {% if section.settings.show_filters %}
                {% for i in (1..3) %}
                    {% assign filter_label = "filter_label_" | append: i %}
                    {% if section.settings[filter_label] != blank %}
                        <button>{{ section.settings[filter_label] }}</button>
                    {% endif %}
                {% endfor %}
            {% endif %}
        </div>
        <h1>{{ section.settings.title | default: collection.title }}</h1>
        <div class="right">
            {% if section.settings.show_view_options %}
                <button aria-label="Vista de lista"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 21"><path stroke="#4E586B" d="M3.5 3.5h5v13h-5zM11.5 3.5h5v13h-5zM6 20h8"/></svg></button>
                <button aria-label="Vista de cuadrícula"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20"><path stroke="#4E586B" d="M3.5 3.5h5v5h-5zM11.5 3.5h5v5h-5zM11.5 11.5h5v5h-5zM3.5 11.5h5v5h-5z"/></svg></button>
            {% endif %}
        </div>
    </div>
    <div class="collection-grid">
        <div class="collection-inner">
            <div class="grid product-grid{% if section.settings.big_cards %} big-cards{% endif %}">
                {% if section.settings.no_sapces %}
                    {% for thisProduct in collection.products %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                {% else %}
                    {% for thisProduct in collection.products limit: 2 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 2 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 4 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 6 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 8 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 10 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 12 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                    <div class="product-card dummy"></div>
                    {% for thisProduct in collection.products limit: 2 offset: 14 %}
                        {% render 'product-card', product: thisProduct %}
                    {% endfor %}
                {% endif %}
                <div class="product-card dummy"></div>
                <div class="product-card dummy"></div>
                <div class="product-card dummy"></div>
                <div class="product-card dummy"></div>
            </div>
        </div>
    </div>
</div>



{% schema %}
{
  "name": "Collection page content",
  "tag": "section",
  "class": "collection-main mw",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título personalizado",        
      "info": "Dejar vacío para usar el título de la colección"
    },
    {
      "type": "header",
      "content": "Filtros"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Mostrar filtros",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_label_1",
      "label": "Filtro 1",
      "default": "Origen"
    },
    {
      "type": "text",
      "id": "filter_label_2",
      "label": "Filtro 2",
      "default": "Proceso"
    },
    {
      "type": "text",
      "id": "filter_label_3",
      "label": "Filtro 3",
      "default": "Notas de sabor"
    },
    {
      "type": "header",
      "content": "Opciones de vista"
    },
    {
      "type": "checkbox",
      "id": "show_view_options",
      "label": "Mostrar opciones de vista",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "checkbox",
      "id": "no_sapces",
      "label": "Remover espacios entre productos"
    },
    {
      "type": "checkbox",
      "id": "big_cards",
      "label": "Tarjetas de producto grandes"
    }
  ]
}
{% endschema %}
