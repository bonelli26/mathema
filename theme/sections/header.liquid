<header>
  <div class="header-icons" style="min-width:140px;">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    {% if customer %}
      <a href="{{ routes.customer_logout_url }}" style="color:var(--cream); font-size:11px; letter-spacing:1.5px;">Cerrar sesión</a>
    {% else %}
      <a href="{{ routes.customer_login_url }}" style="color:var(--cream); font-size:11px; letter-spacing:1.5px;">Crear cuenta</a>
      <a href="{{ routes.customer_login_url }}" style="color:var(--cream); font-size:11px; letter-spacing:1.5px;">Iniciar sesión</a>
    {% endif %}
  </div>
  <div class="logo">
    <a href="{{ routes.root_url }}" class="logo-link">
      <div class="logo-main">{{ shop.name }}</div>
      <div class="logo-sub">Interiorismo · Construcción</div>
    </a>
  </div>
  <div class="header-icons" style="min-width:140px; justify-content:flex-end;">
    <a href="{{ routes.cart_url }}" class="cart-link">
      <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <span class="cart-count">{{ cart.item_count }}</span>
    </a>
  </div>
</header>
