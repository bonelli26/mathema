<div class="product-card" data-product-id="{{ product.id }}" data-product-type="{{ product.type }}">
  <div class="product-image-wrapper">
    <div class="product-image">
      {% if product.featured_image %}
        <img 
          src="{{ product.featured_image | img_url: '500x500' }}" 
          alt="{{ product.title }}" 
          loading="lazy"
          class="product-image-img">
      {% else %}
        <div class="product-image-placeholder"></div>
      {% endif %}
      
      <div class="product-overlay">
        <div class="overlay-content">
          <a href="{% if product.type contains 'Asesoría' %}{{ product.url }}{% else %}{{ product.url }}{% endif %}" 
             class="btn-action" 
             title="{{ product.title }}">
            {% if product.type contains 'Asesoría' %}
              AGENDAR AL CARRITO
            {% else %}
              VER MÁS
            {% endif %}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="product-info">
    <h3 class="product-title">{{ product.title }}</h3>
    
    {% if product.description %}
      <p class="product-desc">{{ product.description | strip_html | truncatewords: 18 }}</p>
    {% endif %}
    
    <div class="product-pricing">
      {% if product.compare_at_price > product.price %}
        <span class="price-original">{{ product.compare_at_price | money }}</span>
      {% endif %}
      <span class="price-current">{{ product.price | money }}</span>
    </div>
  </div>
</div>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .product-image-wrapper {
    width: 100%;
    overflow: hidden;
  }

  .product-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: linear-gradient(135deg, #f5efe7 0%, #ede7dd 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.320, 1);
    display: block;
  }

  .product-image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--cream, #f5efe7);
  }

  .product-card:hover .product-image-img {
    transform: scale(1.06);
  }

  .product-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 26, 14, 0.72);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.23, 1, 0.320, 1);
    backdrop-filter: blur(1px);
  }

  .product-card:hover .product-overlay {
    opacity: 1;
  }

  .overlay-content {
    text-align: center;
    z-index: 2;
  }

  .btn-action {
    display: inline-block;
    padding: 11px 28px;
    background: var(--accent, #b8956a);
    color: #fff;
    border: 2px solid var(--accent, #b8956a);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Jost', sans-serif;
  }

  .btn-action:hover {
    background: transparent;
    color: var(--accent, #b8956a);
    transform: scale(1.05);
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
  }

  .product-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--dark, #2c1a0e);
    margin: 0;
    line-height: 1.3;
    letter-spacing: 0.2px;
  }

  .product-desc {
    font-size: 13px;
    color: var(--gray, #666);
    margin: 0;
    line-height: 1.5;
    font-family: 'Jost', sans-serif;
    font-weight: 300;
  }

  .product-pricing {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 8px;
  }

  .price-original {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
  }

  .price-current {
    font-size: 15px;
    font-weight: 600;
    color: var(--accent, #b8956a);
    font-family: 'Jost', sans-serif;
  }

  @media (max-width: 768px) {
    .product-card {
      gap: 12px;
    }

    .product-title {
      font-size: 18px;
    }

    .product-desc {
      font-size: 12px;
    }

    .btn-action {
      font-size: 10px;
      padding: 10px 24px;
      letter-spacing: 1px;
    }
  }

  @media (max-width: 480px) {
    .product-image {
      aspect-ratio: 4 / 5;
    }

    .product-title {
      font-size: 16px;
    }
  }
</style>
